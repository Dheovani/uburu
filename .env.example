# Uburu local development environment
#
# Copy this file to `.env` and adjust the paths for your machine.
# PowerShell scripts in `scripts/` load `.env` automatically.
# CMake presets still read variables from the process environment, so define
# them in your terminal before running `cmake --preset ...`.

# Required by CMake presets to locate vcpkg dependencies.
VCPKG_ROOT=C:\Users\your-user\vcpkg

# Required by Qt desktop presets and scripts.
# This must point to the Qt CMake prefix, not the top-level C:\Qt folder.
QT_ROOT=C:\Qt\6.11.1\mingw_64

# Required by Windows MinGW presets and scripts.
MINGW_ROOT=C:\Qt\Tools\mingw1310_64

# Required when Ninja is not already available in PATH.
NINJA_ROOT=C:\Qt\Tools\Ninja
