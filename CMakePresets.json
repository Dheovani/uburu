{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "UBURU_BUILD_TESTS": "ON",
        "UBURU_ENABLE_FORMAT_TARGET": "ON",
        "UBURU_ENABLE_LIBGIT2": "ON",
        "UBURU_ENABLE_PCRE2": "ON",
        "UBURU_ENABLE_TIDY_TARGET": "ON"
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Qt desktop build using Visual Studio/MSVC, vcpkg and QT_ROOT.",
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc-debug",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT}",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "description": "Qt desktop build using Ninja, vcpkg and QT_ROOT when Qt is outside the system prefix.",
      "inherits": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT}",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "core-windows-msvc-debug",
      "displayName": "Core-only Windows MSVC Debug",
      "description": "Build only the UI-independent core and tests using Visual Studio/MSVC; does not require Qt.",
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/core-windows-msvc-debug",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "UBURU_BUILD_DESKTOP": "OFF"
      }
    },
    {
      "name": "core-windows-msvc-werror-debug",
      "displayName": "Core-only Windows MSVC Debug with warnings as errors",
      "description": "CI-oriented core build using Visual Studio/MSVC with project warnings promoted to errors.",
      "inherits": "core-windows-msvc-debug",
      "binaryDir": "${sourceDir}/build/core-windows-msvc-werror-debug",
      "cacheVariables": {
        "UBURU_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "core-linux-debug",
      "displayName": "Core-only Linux Debug",
      "description": "Build only the UI-independent core and tests on Linux; does not require Qt.",
      "inherits": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/core-linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "UBURU_BUILD_DESKTOP": "OFF"
      }
    },
    {
      "name": "core-linux-werror-debug",
      "displayName": "Core-only Linux Debug with warnings as errors",
      "description": "CI-oriented core build on Linux with project warnings promoted to errors.",
      "inherits": "core-linux-debug",
      "binaryDir": "${sourceDir}/build/core-linux-werror-debug",
      "cacheVariables": {
        "UBURU_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "core-linux-sanitize-debug",
      "displayName": "Core-only Linux Debug with sanitizers",
      "description": "Core build with AddressSanitizer and UndefinedBehaviorSanitizer enabled.",
      "inherits": "core-linux-debug",
      "binaryDir": "${sourceDir}/build/core-linux-sanitize-debug",
      "cacheVariables": {
        "UBURU_ENABLE_SANITIZERS": "ON",
        "UBURU_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "core-windows-msvc-debug",
      "configurePreset": "core-windows-msvc-debug",
      "configuration": "Debug"
    },
    {
      "name": "core-windows-msvc-werror-debug",
      "configurePreset": "core-windows-msvc-werror-debug",
      "configuration": "Debug"
    },
    {
      "name": "core-linux-debug",
      "configurePreset": "core-linux-debug"
    },
    {
      "name": "core-linux-werror-debug",
      "configurePreset": "core-linux-werror-debug"
    },
    {
      "name": "core-linux-sanitize-debug",
      "configurePreset": "core-linux-sanitize-debug"
    },
    {
      "name": "format",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "targets": ["format"]
    },
    {
      "name": "format-check",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "targets": ["format-check"]
    },
    {
      "name": "tidy",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "targets": ["tidy"]
    }
  ],
  "testPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-windows-msvc-debug",
      "configurePreset": "core-windows-msvc-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-windows-msvc-werror-debug",
      "configurePreset": "core-windows-msvc-werror-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-linux-debug",
      "configurePreset": "core-linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-linux-werror-debug",
      "configurePreset": "core-linux-werror-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-linux-sanitize-debug",
      "configurePreset": "core-linux-sanitize-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
